---
import AuthLayout from "@/layouts/AuthLayout.astro";
import { AuthCard } from "@/components/auth/AuthCard";
import { Redirecting } from "@/components/auth/Redirecting";

// Always show success state since Supabase already verified the email
let verificationStatus = "success";

const content = {
  success: {
    title: "Email verified",
    description: "Your email has been verified. You can now sign in to your account.",
  },
};

const { title, description } = content[verificationStatus];
---

<AuthLayout>
  <AuthCard
    client:load
    title={title}
    description={description}
    footer={{
      type: "link",
      text: "Sign in to your account",
      href: "/auth/login",
    }}
  >
    <div class="flex flex-col items-center gap-4">
      <svg class="h-16 w-16 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      <a href="/auth/login" class="mt-4 px-4 py-2 bg-primary text-white rounded hover:bg-primary/80 transition-colors">
        Sign in
      </a>
      <Redirecting client:load to="/auth/login" message="Redirecting to sign in page" />
    </div>
  </AuthCard>
</AuthLayout>
